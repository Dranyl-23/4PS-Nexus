generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  wallet      String   @unique
  fullName    String
  address     String
  kycStatus          String   @default("pending") // pending, verified, rejected
  accountStatus      String   @default("active") // active, frozen
  lastComplianceDate DateTime? @default(now())
  
  // Settings & Preferences
  smsAlerts          Boolean  @default(true)
  emailAlerts        Boolean  @default(false)
  networkAlerts      Boolean  @default(true)
  complianceReminders Boolean @default(true)
  language           String   @default("cebuano")
  phoneNumber        String?
  email              String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Merchant {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  wallet        String   @unique
  businessName  String
  category      String?
  location      String
  isWhitelisted Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ClaimDocument {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  beneficiary String   // The wallet address of the beneficiary
  category    String
  fileUrl     String
  status      String   @default("pending") // pending, approved, rejected
  submittedAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  beneficiary String   // The wallet address of the beneficiary
  type        String   // 'receive' or 'spend'
  merchant    String   // 'DSWD Disbursement' or merchant name
  category    String
  amount      Float
  status      String   @default("Completed")
  txHash      String
  date        DateTime @default(now())
}

